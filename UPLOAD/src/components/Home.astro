---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getNotionContent } from '../lib/notion.js';

const lang = Astro.currentLocale || 'es';
const t: any = await getNotionContent(lang);
---

<Layout title={t.meta_title || "Sibila — Hay cosas que no se ven, pero se sienten"}>
  <section class="hero">
    <div class="hero-left">
      <div class="hero-eyebrow" set:html={t.hero_eyebrow || "Sibila · Identidad Sensorial · Mallorca"}></div>
      <h1 class="hero-headline" set:html={t.hero_headline || "Hay un lenguaje invisible que habita en el aire, en la memoria y en el cuerpo.<br><em>Yo lo traduzco.</em>"}>
      </h1>
      <p class="hero-sub" set:html={t.hero_sub || "Experiencias olfativas · Arte multisensorial · Identidad aromática<br>Desde la planta, la materia y la emoción."}></p>
      <div class="hero-actions">
        <a href="#services" class="btn-primary">
          <span set:html={t.hero_btn_primary || "Descubrir mis mundos"}></span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="white" stroke-width="1.3" stroke-linecap="round"/></svg>
        </a>
        <a href="#contact" class="btn-ghost" set:html={t.hero_btn_ghost || "Hablemos"}></a>
      </div>
    </div>
    <div class="hero-right">
      <img src="/images/cristaleria.png" alt="Laboratorio olfativo de Sibila" loading="eager">
      <div class="hero-formula" set:html={t.hero_formula || "C₁₀H₁₈O — linalool"}></div>
    </div>
  </section>

  <div class="trust-bar fade-up">
    <div class="trust-item" style="text-align: center; max-width: 600px; margin: 0 auto;">
      <strong style="font-size: 1.5rem; line-height: 1.4; color: var(--amber);" set:html={t.trust_quote || "El viaje no comienza cuando hueles. Comienza cuando algo dentro de ti despierta, responde… y se transforma."}></strong>
    </div>
  </div>

  <section class="about" id="about">
    <div class="about-img fade-up">
      <img src="/images/laboratorio.png" alt="Sibila en su atelier" loading="lazy">
    </div>
    <div class="about-content fade-up">
      <div class="section-label" set:html={t.about_label || "Sobre Mí"}></div>
      <h2 class="about-headline" set:html={t.about_headline || "Soy Itxaso Sibila.<br>Trabajo con el aroma como <em>lenguaje.</em>"}>
      </h2>
      <p class="about-text" set:html={t.about_p1 || "Un lenguaje sutil, invisible y profundamente presente. Entre la ciencia y la naturaleza aprendí a escuchar la materia, a respetar los tiempos de la planta y a reconocer que cada esencia guarda una historia."}></p>
      <p class="about-text" set:html={t.about_p2 || "Desde Mallorca recolecto, destilo y traduzco ese lenguaje en experiencias que tocan el cuerpo —de forma física—, la memoria y la emoción."}></p>
      <blockquote class="about-quote" set:html={t.about_quote || '"Ahí comienza el viaje.<br>Y, con él, la transformación."'}>
      </blockquote>
    </div>
  </section>

  <section class="services" id="services">
    <div class="services-header fade-up">
      <div>
        <div class="section-label light" set:html={t.services_label || "Mis Tres Mundos"}></div>
        <h2 class="services-title" set:html={t.services_title || "Tres formas de dar espacio<br>al lenguaje del <em>aroma.</em>"}>
        </h2>
      </div>
      <div>
        <p class="services-intro" set:html={t.services_intro1 || "Trabajo desde tres mundos que se entrelazan y se alimentan entre sí: la experiencia, la creación y la identidad."}></p>
        <p class="services-intro" set:html={t.services_intro2 || "Todo nace en el mismo lugar: en la escucha de la materia viva. Yo acompaño ese tránsito. Escucho, afino, compongo y revelo. Y desde ahí, el aroma se convierte en experiencia."}></p>
      </div>
    </div>
    <div class="svc-grid">
      <div class="svc-card fade-up">
        <div class="svc-img"><img src="/images/botanica-amber.png" alt="Experiencias olfativas" loading="lazy"></div>
        <div class="svc-num">01</div>
        <div class="svc-tag" set:html={t.svc1_tag || "Workshop · Sensorial · Naturaleza"}></div>
        <h3 class="svc-name" set:html={t.svc1_name || "Experiencias Olfativas"}></h3>
        <p class="svc-desc" set:html={t.svc1_desc || "Creo experiencias donde el aroma abre el recorrido y afina la percepción. Espacios para detenerse, respirar, sentir y recordar de otra manera. Trabajo con grupos, retiros, eventos y lugares que desean algo más que una actividad."}></p>
        <a href="/experiencias" class="svc-link" set:html={t.svc1_link || "Explorar →"}></a>
      </div>
      <div class="svc-card fade-up">
        <div class="svc-img"><img src="/images/botanica-herbs.png" alt="Arte multisensorial" loading="lazy"></div>
        <div class="svc-num">02</div>
        <div class="svc-tag" set:html={t.svc2_tag || "Colaboración · Arte · Cultura"}></div>
        <h3 class="svc-name" set:html={t.svc2_name || "Arte Multisensorial"}></h3>
        <p class="svc-desc" set:html={t.svc2_desc || "¿Y si tu obra también se pudiera oler? Trabajo con el aroma como una dimensión más de la creación. Colaboro con músicos, artistas, festivales y proyectos culturales para abrir un lugar al olfato dentro de la narrativa."}></p>
        <a href="/arte" class="svc-link" set:html={t.svc2_link || "Explorar →"}></a>
      </div>
      <div class="svc-card fade-up">
        <div class="svc-img"><img src="/images/cristaleria.png" alt="Identidad olfativa" loading="lazy"></div>
        <div class="svc-num">03</div>
        <div class="svc-tag" set:html={t.svc3_tag || "Branding · Identidad · Marca"}></div>
        <h3 class="svc-name" set:html={t.svc3_name || "Identidad Olfativa"}></h3>
        <p class="svc-desc" set:html={t.svc3_desc || "Tu marca ya está comunicando, incluso antes de ser mirada. Trabajo creando identidades olfativas para hoteles, espacios, marcas y proyectos que desean encarnar una presencia propia y dejar un rastro inolvidable."}></p>
        <a href="/marca" class="svc-link" set:html={t.svc3_link || "Explorar →"}></a>
      </div>
    </div>
  </section>

  <div class="hook fade-up">
    <p class="hook-pre" set:html={t.hook_pre || "Tu diferencia"}></p>
    <h2 class="hook-headline" set:html={t.hook_headline || "No perfumo espacios.<br><em>Compongo experiencias.</em>"}>
    </h2>
    <p class="hook-text" set:html={t.hook_text || "Trabajo desde la materia viva —la planta, la molécula, el aceite esencial— y desde aquello que no se ve: la emoción, la memoria, la percepción. Porque cuando la materia está viva, el aroma no solo huele: acompaña, sostiene y transforma."}></p>
    <div class="hook-actions">
      <a href="#contact" class="btn-primary" set:html={t.hook_btn || "Quiero crear algo único"}></a>
    </div>
  </div>

  <section class="projects-home" id="projects">
    <div class="section-label fade-up" set:html={t.proj_label || "Proyectos Destacados"}></div>
    <div class="proj-grid">
      <div class="proj-card fade-up">
        <div class="proj-img"><img src="/images/cristaleria.png" alt="Festival Flamenco" loading="lazy"></div>
        <div class="proj-info">
          <div class="proj-cat" set:html={t.proj1_cat || "Arte · Festival · Jerez"}></div>
          <div class="proj-title" set:html={t.proj1_title || "Festival de Flamenco"}></div>
          <p class="proj-desc" set:html={t.proj1_desc || "Una composición que no describe, sino que atraviesa."}></p>
        </div>
      </div>
      <div class="proj-card fade-up">
        <div class="proj-img"><img src="/images/botanica-amber.png" alt="Marco Mezquida" loading="lazy"></div>
        <div class="proj-info">
          <div class="proj-cat" set:html={t.proj2_cat || "Arte · Concierto · Barcelona"}></div>
          <div class="proj-title" set:html={t.proj2_title || "Marco Mezquida"}></div>
          <p class="proj-desc" set:html={t.proj2_desc || "El aroma como capa invisible que dialoga con la música."}></p>
        </div>
      </div>
      <div class="proj-card fade-up">
        <div class="proj-img"><img src="/images/botanica-herbs.png" alt="Exposición" loading="lazy"></div>
        <div class="proj-info">
          <div class="proj-cat" set:html={t.proj3_cat || "Arte · Exposición · Valldemossa"}></div>
          <div class="proj-title" set:html={t.proj3_title || "Jordi Miralles"}></div>
          <p class="proj-desc" set:html={t.proj3_desc || "El olfato como presencia dentro de la obra."}></p>
        </div>
      </div>
      <div class="proj-card fade-up">
        <div class="proj-img"><img src="/images/laboratorio.png" alt="Vestido de novia" loading="lazy"></div>
        <div class="proj-info">
          <div class="proj-cat" set:html={t.proj4_cat || "Marca · Emoción"}></div>
          <div class="proj-title" set:html={t.proj4_title || "Narrativa olfativa de novia"}></div>
          <p class="proj-desc" set:html={t.proj4_desc || "Una identidad que se lleva, se siente… y permanece."}></p>
        </div>
      </div>
    </div>
    <div style="text-align:center;margin-top:40px;">
      <a href="/proyectos" class="btn-ghost" set:html={t.proj_btn_all || "Ver todos los proyectos →"}></a>
    </div>
  </section>

  <section class="lm" id="guia">
    <div class="lm-inner">
      <div class="fade-up">
        <div class="section-label light" set:html={t.lm_label || "Guía Gratuita"}></div>
        <h2 class="lm-headline" set:html={t.lm_headline || "Volver a oler<br><em>el mundo.</em>"}>
        </h2>
        <p class="lm-text" set:html={t.lm_text || "Hemos aprendido a mirar, a escuchar, a pensar. Pero hemos olvidado cómo oler. El olfato es el único sentido que conecta directamente con la memoria y la emoción."}></p>
        <ul class="lm-list">
          <li set:html={t.lm_list_1 || "El paseo olfativo de 10 minutos que cambia todo"}></li>
          <li set:html={t.lm_list_2 || "Cómo crear tu mapa personal de aromas y memorias"}></li>
          <li set:html={t.lm_list_3 || "El ejercicio de los cinco elementos mediterráneos"}></li>
        </ul>
      </div>
      <form class="lm-form fade-up" name="guia-gratuita" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
        <input type="hidden" name="form-name" value="guia-gratuita">
        <input type="hidden" name="bot-field" style="display:none">
        <div class="lm-group">
          <input class="lm-input" type="text" name="nombre" placeholder={t.lm_ph_name || "Tu nombre"} required>
          <div class="lm-line"></div>
        </div>
        <div class="lm-group">
          <input class="lm-input" type="email" name="email" placeholder={t.lm_ph_email || "Tu email"} required>
          <div class="lm-line"></div>
        </div>
        <button class="lm-submit" type="submit" set:html={t.lm_btn || "Quiero mi guía →"}></button>
        <p class="lm-note" set:html={t.lm_note || "Sin ruido. Sin fórmulas. Solo una invitación a volver a sentir."}></p>
      </form>
    </div>
  </section>

  <section class="contact-section" id="contact">
    <div class="fade-up">
      <div class="section-label" set:html={t.contact_label || "Contacto"}></div>
      <h2 class="contact-headline" set:html={t.contact_headline || "Todo empieza<br>con una<br><em>conversación.</em>"}>
      </h2>
      <p class="contact-text" set:html={t.contact_text || "Cuéntame qué quieres crear. Qué emoción quieres despertar. Qué experiencia necesita tomar forma. A veces no falta la idea. Falta el lenguaje. Y el aroma puede abrir ese espacio."}></p>
      <div class="contact-opts">
        <a href="https://wa.me/34608543705" class="copt" target="_blank">
          <div class="copt-icon wa"><svg width="20" height="20" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg></div>
188:           <div><div class="copt-label" set:html={t.contact_wa_label || "Hablemos por WhatsApp"}></div><div class="copt-val" set:html={t.contact_wa_val || "Escríbeme y hablamos"}></div></div>
189:         </a>
190:         <a href="mailto:info@itxasosibila.es" class="copt">
191:           <div class="copt-icon em"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
192:           <div><div class="copt-label" set:html={t.contact_em_label || "Email"}></div><div class="copt-val" set:html={t.contact_em_val || "info@itxasosibila.es"}></div></div>
193:         </a>
194:       </div>
195:     </div>
196:     <form class="cform fade-up" name="contacto" method="POST" data-netlify="true" data-netlify-honeypot="bot-field">
197:       <input type="hidden" name="form-name" value="contacto">
198:       <input type="hidden" name="bot-field" style="display:none">
199:       <div class="cform-group"><input class="cform-input" type="text" name="nombre" placeholder={t.cform_ph_name || "Tu nombre"} required><div class="cform-line"></div></div>
200:       <div class="cform-group"><input class="cform-input" type="email" name="email" placeholder={t.cform_ph_email || "Tu email"} required><div class="cform-line"></div></div>
201:       <div class="cform-group"><input class="cform-input" type="text" name="tipo" placeholder={t.cform_ph_type || "¿Experiencias, Arte o Marca?"}><div class="cform-line"></div></div>
202:       <div class="cform-group"><textarea class="cform-textarea" name="mensaje" placeholder={t.cform_ph_msg || "Cuéntame tu proyecto…"}></textarea><div class="cform-line"></div></div>
203:       <button class="cform-submit" type="submit" set:html={t.cform_btn || "Enviar mensaje"}></button>
204:     </form>
205:   </section>
206: </Layout>
