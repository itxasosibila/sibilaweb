---
import Layout from '../layouts/Layout.astro';
import { getNotionContent } from '../lib/notion.js';

const lang = Astro.currentLocale || 'es';
const t: any = await getNotionContent(lang);

const prefix = lang === 'es' ? '' : `/${lang}`;
---

<Layout title={t.mar_meta_title || "Consultoría Aromática para Marcas — Sibila"}>
<div class="page-hero sub-hero-img fade-up">
  <div class="page-hero-eyebrow" set:html={t.mar_hero_eyebrow || "Sibila · Mundo 03"}></div>
  <h1 set:html={t.mar_hero_headline || "Tu marca tiene<br>un aroma,<br><em>aunque no lo sepa.</em>"}></h1>
  <p class="page-hero-sub" set:html={t.mar_hero_sub || "Identidades olfativas que definen hoteles, espacios de diseño y productos exclusivos. La firma invisible de tu marca."}></p>
</div>

<section class="marca-problem">
  <div class="marca-problem-text fade-up">
    <h2 set:html={t.mar_prob_headline || "Las marcas que se recuerdan<br><em>no solo se ven.</em>"}></h2>
    <p set:html={t.mar_prob_p1 || "Las marcas invierten millones en identidad visual y sonora, saturando todos los canales de comunicación. Pero pocas dominan la dimensión sensorial más poderosa: el olfato."}></p>
    <p set:html={t.mar_prob_p2 || "Un aroma puede aumentar la permanencia en un espacio hasta un 20%, incrementar ventas y generar reconocimiento de marca inmediato. No se trata de perfumar — se trata de comunicar."}></p>
  </div>
  <div class="marca-stats fade-up">
    <div class="stat"><div class="stat-num">20%</div><div class="stat-text" set:html={t.mar_stat1 || "Incremento en tiempo de permanencia en el espacio"}></div></div>
    <div class="stat"><div class="stat-num">15%</div><div class="stat-text" set:html={t.mar_stat2 || "Incremento en ventas documentado en retail"}></div></div>
    <div class="stat"><div class="stat-num">65%</div><div class="stat-text" set:html={t.mar_stat3 || "Incremento en el recuerdo de marca"}></div></div>
  </div>
</section>

<section class="marca-process">
  <div class="section-label light fade-up" set:html={t.mar_proc_label || "El proceso"}></div>
  <div class="marca-steps">
    <div class="marca-step fade-up">
      <div class="marca-step-n">01</div>
      <div class="marca-step-title" set:html={t.mar_proc1_title || "Brief sensorial"}></div>
      <p class="marca-step-text" set:html={t.mar_proc1_text || "Análisis profundo de tu marca: valores, público, espacios físicos y experiencia deseada."}></p>
    </div>
    <div class="marca-step fade-up">
      <div class="marca-step-n">02</div>
      <div class="marca-step-title" set:html={t.mar_proc2_title || "Creación"}></div>
      <p class="marca-step-text" set:html={t.mar_proc2_text || "Desarrollo de muestras personalizadas. Iteraciones hasta encontrar la composición perfecta."}></p>
    </div>
    <div class="marca-step fade-up">
      <div class="marca-step-n">03</div>
      <div class="marca-step-title" set:html={t.mar_proc3_title || "Implementación"}></div>
      <p class="marca-step-text" set:html={t.mar_proc3_text || "Diseño del sistema de difusión adecuado para cada espacio. Formación del equipo."}></p>
    </div>
    <div class="marca-step fade-up">
      <div class="marca-step-n">04</div>
      <div class="marca-step-title" set:html={t.mar_proc4_title || "Mantenimiento"}></div>
      <p class="marca-step-text" set:html={t.mar_proc4_text || "Seguimiento continuo y ajustes estacionales para que el aroma evolucione con tu marca."}></p>
    </div>
  </div>
</section>

<section class="marca-cases">
  <div class="section-label fade-up" set:html={t.mar_cases_label || "Casos de éxito"}></div>
  <div class="cases-grid">
    <div class="case-card fade-up">
      <div class="case-title" set:html={t.mar_case1_title || "Hotel boutique"}></div>
      <p class="case-text" set:html={t.mar_case1_text || "Fragancia mediterránea con notas de limón de Sóller, sal marina y maderas locales. Incremento del 35% en menciones positivas sobre la experiencia del huésped."}></p>
    </div>
    <div class="case-card fade-up">
      <div class="case-title" set:html={t.mar_case2_title || "Marca de moda sostenible"}></div>
      <p class="case-text" set:html={t.mar_case2_text || "Aroma de algodón orgánico, té verde y cedro para puntos de venta. Coherencia total con los valores ecológicos de la marca."}></p>
    </div>
    <div class="case-card fade-up">
      <div class="case-title" set:html={t.mar_case3_title || "Estudio de arquitectura"}></div>
      <p class="case-text" set:html={t.mar_case3_text || "Fragancia característica para showroom: hormigón, madera de roble y notas minerales reflejando su estilo contemporáneo."}></p>
    </div>
  </div>
</section>

<div class="sub-cta fade-up">
  <h2 set:html={t.mar_cta_headline || "¿Cuándo empezamos<br>a crear tu <em>firma olfativa?</em>"}></h2>
  <p set:html={t.mar_cta_sub || "Todo empieza con una conversación. Sin tarifas en la web — cada proyecto es único."}></p>
  <div class="sub-cta-btns">
    <a href={`${prefix}/#contact`} class="btn-primary" set:html={t.mar_cta_btn1 || "Diseña tu identidad aromática"}></a>
    <a href="https://wa.me/34608543705" class="btn-ghost" target="_blank" set:html={t.mar_cta_btn2 || "💬 WhatsApp"}></a>
  </div>
</div>
</Layout>

<style>
.sub-hero-img{background-image:url('/images/laboratorio.png');}
.marca-problem{padding:90px 80px;background:var(--cream);display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:center;}
.marca-problem-text h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3vw,3rem);font-weight:300;color:var(--dark);margin-bottom:20px;line-height:1.2;}
.marca-problem-text h2 em{font-style:italic;color:var(--amber);}
.marca-problem-text p{font-size:.88rem;font-weight:300;line-height:1.9;color:var(--text-muted);margin-bottom:14px;}
.marca-stats{display:flex;flex-direction:column;gap:16px;}
.stat{padding:28px 32px;background:var(--dark);display:flex;align-items:center;gap:24px;}
.stat-num{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;color:var(--amber);line-height:1;flex-shrink:0;}
.stat-text{font-size:.8rem;font-weight:300;color:rgba(245,240,232,.55);line-height:1.7;}
.marca-process{padding:90px 80px;background:var(--dark);}
.marca-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:2px;margin-top:48px;}
.marca-step{padding:40px 30px;border:1px solid rgba(255,255,255,.05);}
.marca-step-n{font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:rgba(200,134,42,.2);margin-bottom:16px;}
.marca-step-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-style:italic;color:var(--cream);margin-bottom:10px;}
.marca-step-text{font-size:.8rem;font-weight:300;line-height:1.9;color:rgba(245,240,232,.4);}
.marca-cases{padding:90px 80px;background:var(--cream);}
.cases-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;margin-top:48px;}
.case-card{padding:36px 32px;background:var(--warm-white);border-bottom:3px solid transparent;transition:border-color .3s;}
.case-card:hover{border-color:var(--amber);}
.case-title{font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-style:italic;color:var(--dark);margin-bottom:12px;}
.case-text{font-size:.82rem;font-weight:300;line-height:1.9;color:var(--text-muted);}
.sub-cta{padding:90px 80px;background:var(--dark);text-align:center;}
.sub-cta h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3.5rem);font-weight:300;color:var(--cream);margin-bottom:20px;}
.sub-cta h2 em{font-style:italic;color:var(--amber);}
.sub-cta p{font-size:.9rem;font-weight:300;color:rgba(245,240,232,.45);line-height:1.9;max-width:500px;margin:0 auto 36px;}
.sub-cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;}
@media(max-width:768px){
  .marca-problem,.marca-process,.marca-cases,.sub-cta{padding:60px 20px;}
  .marca-problem{grid-template-columns:1fr;}
  .marca-steps{grid-template-columns:1fr 1fr;}
  .cases-grid{grid-template-columns:1fr;}
}
</style>